# ============================================================
# PhoneBase — конфигурация окружения
# Скопируйте в .env и заполните. Файл .env НИКОГДА не коммитить в git!
# ============================================================

# База данных
POSTGRES_DB=phonebase
POSTGRES_USER=phonebase
POSTGRES_PASSWORD=СГЕНЕРИРУЙТЕ_СЛУЧАЙНЫЙ_ПАРОЛЬ_32_СИМВОЛА

# Redis
REDIS_PASSWORD=СГЕНЕРИРУЙТЕ_СЛУЧАЙНЫЙ_ПАРОЛЬ_32_СИМВОЛА

# Безопасность приложения
SECRET_KEY=СГЕНЕРИРУЙТЕ_256_БИТ_HEX  # python -c "import secrets; print(secrets.token_hex(32))"

# Ключ шифрования персональных данных (152-ФЗ)
# ХРАНИТЬ ОТДЕЛЬНО ОТ БД! В продакшне — использовать Vault или HSM
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PD_ENCRYPTION_KEY=СГЕНЕРИРУЙТЕ_FERNET_KEY

# Домен (через запятую, без пробелов или с пробелами — обрежутся)
# Для локального API добавьте: localhost,127.0.0.1
# Переопределение для разработки: файл backend/.env (ENVIRONMENT=development)
ALLOWED_HOSTS=yourdomain.ru,www.yourdomain.ru

# Публичный URL сайта API (для ссылок на фото в XML-фиде Авито, например https://basestock.ru)
PUBLIC_URL=https://yourdomain.ru

# Среда
ENVIRONMENT=production

# (Опционально) Импорт 1С: локальный файл (путь от каталога backend/) или URL.
# Локальный путь имеет приоритет над ссылкой.
# Если задано — после каждого успешного входа выполняется фоновая синхронизация каталога (и через POST /api/imports/from-configured-url).
# IMPORT_1C_HTML_PATH=fixtures/used-phones-1c-html4.html
# IMPORT_1C_HTML_URL=https://drive.google.com/file/d/XXXX/view?usp=sharing

# (Опционально) Импорт НОВЫХ товаров из 1С: локальный файл (путь от каталога backend/) или URL.
# Локальный путь имеет приоритет над ссылкой.
# IMPORT_1C_NEW_HTML_PATH=fixtures/new-phones-1c.html
# IMPORT_1C_NEW_HTML_URL=https://drive.google.com/file/d/XXXX/view?usp=sharing

# Интервал автоматического импорта из файлов (в минутах, 0 — отключено)
# IMPORT_INTERVAL_MINUTES=30

# Каталог документов закупки (подпапки по IMEI/S/N). По умолчанию ./purchase_docs рядом с backend.
# PURCHASE_DOCS_ROOT=./purchase_docs

# ── Firecrawl — парсинг изображений товаров с biggeek.ru ─────────────────────
# Получите ключ на https://firecrawl.dev → Dashboard → API Keys
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Avito REST API — фоновые задачи (интервалы в минутах, 0 — отключено) ─────

# Статистика: сбор просмотров, контактов и избранного по объявлениям.
# Данные отображаются в разделе «Статистика» карточки товара.
# AVITO_STATS_INTERVAL_MINUTES=60

# Сообщения: загрузка входящих/исходящих сообщений из мессенджера Авито.
# Данные отображаются в разделе «Сообщения» карточки товара.
# AVITO_MESSENGER_INTERVAL_MINUTES=5

# Автозагрузка: проверка отчётов автозагрузки фида и маппинг avito_item_id
# к товарам по IMEI или модели+памяти+состоянию.
# Данные отображаются в разделе «Статистика» карточки товара.
# AVITO_FEED_CHECK_INTERVAL_MINUTES=120

# ── Trade-in фид ────────────────────────────────────────────────────────────
# Токен для защищённого доступа к /api/feeds/tradein-prices.json
# (используется сторонними сайтами, например мобилакс.рф, для получения
# агрегированных цен на б/у технику). Сгенерировать: openssl rand -hex 32
# TRADEIN_FEED_TOKEN=

# ── Сайты-витрины (multi-tenant публичный API) ────────────────────────────────
# Разрешённые CORS-origins для фронтендов витрин (через запятую)
# SITE_ORIGINS=https://мобилакс.рф,https://айпрас.рф,https://ремгсм.рф

# URL для редиректа после успешной OAuth-авторизации посетителя
# SITE_RETURN_URL=https://мобилакс.рф

# Домен для HttpOnly cookie сессии посетителя (пусто = текущий хост, для кросс-субдомена: .basestock.ru)
# SITE_SESSION_COOKIE_DOMAIN=

# Срок жизни сессии посетителя в днях (по умолчанию 30)
# SITE_SESSION_DAYS=30

# ── OAuth VK ID ───────────────────────────────────────────────────────────────
# Получить: https://id.vk.com/about/business/go → Создать приложение → тип «Сайт»
# VK_APP_ID=
# VK_APP_SECRET=
# VK_REDIRECT_URI=https://shop.basestock.ru/api/sites/{store_id}/auth/vk/callback

# ── OAuth Telegram Login Widget ───────────────────────────────────────────────
# Токен бота, который настроен как источник авторизации через @BotFather → /setdomain
# TELEGRAM_BOT_TOKEN=
